# Discord required
TOKEN=
GUILD_ID=
CHANNEL_ID=

# Telegram application notifications (optional; set both values)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ANNOUNCEMENTS_CHAT_ID=
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=
DISCORD_ANNOUNCER_ROLE_IDS=
DISCORD_ONLINE_GUILD_ID=

# Support tickets (optional, required to create support channels)
TICKET_CATEGORY_ID=
TICKET_SUPPORT_ROLE_ID=
TICKET_LOG_CHANNEL_ID=
TICKET_PANEL_CHANNEL_ID=
TICKET_PING_SUPPORT=true
TICKET_COOLDOWN_SECONDS=60
TICKET_MAX_OPEN_PER_USER=1
TICKET_DELETE_DELAY_SECONDS=5

# AFK leave module (optional)
AFK_CHANNEL_ID=
AFK_LOG_CHANNEL_ID=
AFK_MANAGER_ROLE_ID=
AFK_APPROVED_ROLE_ID=
AFK_USE_MODAL=true
AFK_USE_MESSAGE_FORM=true
AFK_ALLOW_DM_NOTIFY=true
AFK_PIN_PANEL=true
AFK_PREVENT_DUPLICATE_PANEL=true

# Server backup to GitHub (optional)
SERVER_BACKUP_ENABLED=false
SERVER_BACKUP_INTERVAL_HOURS=48
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_OWNER=
GITHUB_BACKUP_REPO=
GITHUB_BACKUP_BRANCH=main
GITHUB_BACKUP_BASE_PATH=backups/server

# Persistent storage paths (optional locally — defaults to dist-ts/storage.json
# и dist-ts/database.json). На Railway обязательно укажи путь к persistent
# volume, иначе данные теряются при redeploy:
#   DATABASE_FILE=/data/database.json
#   STORAGE_FILE=/data/storage.json
# Scam/gift phishing guard (optional; enabled by default)
SCAM_GUARD_ENABLED=true
SCAM_GUARD_TIMEOUT_MINUTES=1440
SCAM_GUARD_ALLOWED_ROLES=
SCAM_GUARD_GIF_URL=

DATABASE_FILE=
STORAGE_FILE=

# Discord optional
APPLICATIONS_CHANNEL_ID=
LOG_CHANNEL_ID=
DISCIPLINE_LOG_CHANNEL_ID=
MESSAGE_ID=

# Panel and applications
UPDATE_INTERVAL_MS=60000
APPLICATION_COOLDOWN_MS=300000
APPLICATION_TICKET_DELETE_DELAY_SECONDS=5
APPLICATION_DEFAULT_ROLE=
FAMILY_TITLE=🏠 Семья

# Access
ACCESS_APPLICATIONS=
ACCESS_DISCIPLINE=
ACCESS_RANKS=

# Family roles
ROLE_RANK_15=
ROLE_RANK_14=
ROLE_RANK_13=
ROLE_RANK_12=
ROLE_RANK_11=
ROLE_RANK_10=
ROLE_RANK_9=
ROLE_RANK_8=
ROLE_RANK_7=
ROLE_RANK_6=
ROLE_LEADER=
ROLE_DEPUTY=
ROLE_ELDER=
ROLE_MEMBER=
ROLE_NEWBIE=

# Auto ranks by activity
AUTO_RANKS_ENABLED=false
AUTO_RANKS_INTERVAL_MS=300000
AUTO_RANK_MEMBER_MIN_SCORE=50
AUTO_RANK_ELDER_MIN_SCORE=150

# Security
LEAK_GUARD_ENABLED=true
LEAK_GUARD_ALLOWED_ROLES=
CHANNEL_GUARD_ENABLED=true
CHANNEL_GUARD_ALLOWED_ROLES=

# AI helper (DeepSeek is optional; without a key /law uses local search)
AI_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
BOT_OWNER_IDS=
