{
  "name": "family-bot-ai-majestic",
  "version": "1.0.72",
  "engines": {
    "node": ">=18"
  },
  "main": "dist-ts/index.js",
  "scripts": {
    "start": "npm run build:ts && node dist-ts/index.js",
    "test": "node tests/run.js",
    "check": "npm run typecheck && npm run build:ts && node scripts/check.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:ts": "tsc -p tsconfig.json",
    "start:ts": "node dist-ts/index.js",
    "law:import": "node scripts/import-law.js",
    "cabinet:install": "npx playwright install --with-deps chromium",
    "cabinet:login": "node scripts/cabinet-login.js",
    "cabinet:session:check": "node scripts/cabinet-session.js check",
    "cabinet:session:export": "node scripts/cabinet-session.js export",
    "cabinet:session:import": "node scripts/cabinet-session.js import",
    "cabinet:session:cookies": "node scripts/cabinet-session.js cookies",
    "cabinet:session:brave": "node scripts/cabinet-cdp-session.js"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "playwright": "^1.61.1",
    "telegraf": "^4.16.3"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "cheerio": "^1.0.0",
    "typescript": "~6.0.2"
  }
}
